{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Kubernetes Group",
      "groupName": "kubernetes",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 1
    },
    {
      "description": "Rook-Ceph Group",
      "groupName": "rook-ceph",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/rook-ceph/",
        "/rook-ceph-cluster/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 1
    },
    {
      "description": "Talos Group",
      "groupName": "talos",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/installer/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 1
    },
    {
      "description": "Teleport Group",
      "groupName": "Teleport",
      "matchPackagePatterns": [
        "teleport-cluster",
        "teleport-kube-agent"
      ],
      "matchDatasources": [
        "helm"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 1
    },
    {
      "description": "Tdarr Group",
      "groupName": "tdarr",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/haveagitgat/tdarr",
        "ghcr.io/haveagitgat/tdarr_node"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 1
    },
    {
      "description": "Mise TOML File Updates",
      "groupName": "Mise",
      "fileMatch": [
        "(^|/)\\.mise\\.toml$"
      ],
      "matchManagers": [
        "mise"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} file"
      },
      "minimumGroupSize": 1
    }
  ]
}